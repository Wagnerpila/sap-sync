# ---------- SAP ----------
# Home do Fiori Launchpad (sem #hash de app) - o script clica no tile para
# abrir a pesquisa, pois deep links com hash nao funcionam de forma confiavel
# num navegador sem sessao ainda.
SAP_HOME_URL=https://s4prd.sap.klabin.net/sap/bc/ui2/flp?sap-client=400&sap-language=PT
SAP_TILE_TEXT=Procurar nota de manutenção

# Login e automatico via SSO nesse ambiente - as variaveis abaixo ficam como
# fallback caso um dia apareca um formulario de login (ex: sessao expirada).
SAP_USER=
SAP_PASSWORD=
SAP_USER_SELECTOR=#USERNAME_FIELD-inner
SAP_PASSWORD_SELECTOR=#PASSWORD_FIELD-inner
SAP_LOGIN_BUTTON_SELECTOR=#LOGIN_LINK

# Botao que dispara a pesquisa (precisa clicar para o filtro "Hoje" recalcular a data atual a cada execucao)
SAP_SEARCH_BUTTON_TEXT=Iniciar

# Texto do item "Exportar" dentro do menu "..." (mais acoes) da tabela
SAP_EXPORT_BUTTON_TEXT=Exportar

# ---------- base44 ----------
# Painel do app base44 > API - appId e api_key do seu app
BASE44_APP_ID=coloque_o_app_id_aqui
BASE44_API_KEY=coloque_sua_api_key_aqui

# ---------- Execucao ----------
# true = mostra o navegador (bom para debug), false = roda invisivel (producao/agendado)
HEADLESS=false
